# ---------------------------------------------------------------------------
# YourBid environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# The Anthropic API key is used ONLY on the server side (serverless function /
# dev API server). It is never bundled into the client. Do NOT prefix it with
# VITE_ or it would be exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model used for item generation. Defaults to a Sonnet model if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Port for the local dev API server (server/dev-server.mjs). Optional.
API_PORT=8787
